  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
    }

    body {
      background: #0b0e1a;
      color: #e8edf5;
      line-height: 1.5;
    }

    .container {
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* 导航 */
    .navbar {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      padding: 18px 0;
      border-bottom: 1px solid #2a3040;
    }

    .logo-area {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo-icon {
      font-size: 2.2rem;
      color: #f5c842;
    }

    .logo-text {
      font-weight: 700;
      font-size: 1.7rem;
      letter-spacing: 1px;
      background: linear-gradient(135deg, #f5d742, #f0b31c);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .nav-links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 28px;
      font-weight: 500;
    }

    .nav-links a {
      color: #c8d0e6;
      text-decoration: none;
      font-size: 1rem;
      transition: 0.2s;
      border-bottom: 2px solid transparent;
      padding-bottom: 4px;
    }

    .nav-links a:hover {
      color: #f5c842;
      border-bottom-color: #f5c842;
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .avatar-link {
      display: flex;
      align-items: center;
      gap: 8px;
      background: #1f2538;
      padding: 6px 16px 6px 10px;
      border-radius: 40px;
      border: 1px solid #3a425a;
      transition: 0.2s;
      cursor: default;
    }

    .avatar-link img {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: cover;
      background: #2f3650;
      border: 2px solid #f5c842;
    }

    .avatar-link .fa-chevron-down {
      font-size: 0.7rem;
      color: #aab2cc;
      margin-left: 4px;
    }

    .contact-phone {
      background: #1f2538;
      padding: 8px 16px;
      border-radius: 40px;
      border: 1px solid #3f4865;
      color: #f5e7c8;
      font-weight: 500;
      white-space: nowrap;
      cursor: default;
    }

    .contact-phone i {
      color: #4caf7a;
      margin-right: 8px;
    }

    /* 横幅 hero */
    .hero {
      background: linear-gradient(145deg, #12172b, #080b16);
      border-radius: 32px;
      margin: 28px 0 36px 0;
      padding: 50px 20px 40px;
      text-align: center;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.7);
      border: 1px solid #2d344a;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: -30%;
      left: -20%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 40%, rgba(245, 200, 66, 0.04), transparent 70%);
      pointer-events: none;
    }

    .hero h2 {
      font-size: 2.2rem;
      font-weight: 300;
      letter-spacing: 3px;
      margin-bottom: 8px;
      color: #eef3ff;
    }

    .hero h2 span {
      font-weight: 700;
      color: #f5c842;
    }

    .hero-sub {
      color: #9aa3c2;
      margin-bottom: 32px;
      font-size: 1rem;
    }

    .hero-buttons {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 20px 28px;
    }

    .btn-hero {
      background: #1f263e;
      border: none;
      padding: 14px 40px;
      border-radius: 60px;
      font-weight: 700;
      font-size: 1.1rem;
      color: #fff;
      cursor: pointer;
      box-shadow: 0 4px 0 #0b0e1a, 0 8px 20px rgba(0,0,0,0.5);
      transition: 0.15s;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid #3d465f;
      letter-spacing: 0.5px;
      text-decoration: none;
    }

    .btn-hero i {
      color: #f5c842;
      font-size: 1.2rem;
    }

    .btn-hero.primary {
      background: #f5c842;
      color: #0b0e1a;
      border-color: #f5c842;
      box-shadow: 0 4px 0 #a5811e, 0 8px 20px rgba(245, 200, 66, 0.25);
    }

    .btn-hero.primary i {
      color: #0b0e1a;
    }

    .btn-hero:hover {
      transform: scale(1.02);
      filter: brightness(1.1);
    }

    /* 两列布局 */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      margin: 40px 0;
    }

    @media (max-width: 960px) {
      .main-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }
    }

    .about-section {
      background: #141a2b;
      border-radius: 28px;
      padding: 30px 28px;
      border: 1px solid #2a3147;
      box-shadow: 0 6px 18px rgba(0,0,0,0.4);
    }

    .about-title {
      font-size: 1.9rem;
      font-weight: 600;
      letter-spacing: 1px;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .about-title i {
      color: #f5c842;
      font-size: 1.8rem;
    }

    .about-desc {
      color: #cbd2e8;
      margin-bottom: 20px;
      font-size: 1rem;
    }

    .about-desc strong {
      color: #f5d76e;
    }

    .company-intro {
      background: #0f1424;
      padding: 18px 20px;
      border-radius: 20px;
      border-left: 4px solid #f5c842;
      margin: 18px 0;
    }

    .company-intro h4 {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
      color: #f5c842;
    }

    .company-intro p {
      color: #bfc8e0;
      font-size: 0.95rem;
    }

    .feature-tags {
