      margin-top: 10px;
    }

    .access-section {
      background: #101726;
      border-radius: 24px;
      padding: 18px 24px;
      margin: 20px 0 18px;
      border-left: 6px solid #f5c842;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
    }

    .access-section span {
      color: #cbd2ea;
    }

    .access-section .access-link {
      background: #1f253e;
      padding: 8px 24px;
      border-radius: 40px;
      color: #f5d76e;
      border: 1px solid #4c567a;
      font-weight: 500;
      text-decoration: none;
    }

    .footer-note {
      margin-top: 40px;
      padding: 20px 0;
      border-top: 1px solid #232b41;
      text-align: center;
      color: #6d789b;
      font-size: 0.9rem;
    }

    /* 客服弹窗 */
    .phone-popup {
      display: none;
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0,0,0,0.65);
      align-items: center;
      justify-content: center;
      z-index: 999;
      backdrop-filter: blur(3px);
    }
    .phone-popup.active {
      display: flex;
    }
    .phone-popup-content {
      background: #1a2138;
      max-width: 380px;
      width: 90%;
      padding: 30px 24px 24px;
      border-radius: 40px;
      border: 1px solid #f5c842;
      box-shadow: 0 20px 40px rgba(0,0,0,0.7);
      text-align: center;
      animation: popIn 0.25s ease;
    }
    @keyframes popIn {
      0% { transform: scale(0.85); opacity: 0.6; }
      100% { transform: scale(1); opacity: 1; }
    }
    .phone-popup-content h3 {
      color: #f5c842;
      font-size: 1.4rem;
      margin-bottom: 6px;
    }
    .phone-popup-content .phone-number {
      font-size: 2rem;
      font-weight: 700;
      color: #fff;
      background: #0e1325;
      padding: 10px 12px;
      border-radius: 60px;
      margin: 12px 0 20px;
      border: 1px solid #3d4668;
      letter-spacing: 1px;
    }
    .popup-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
    }
    .popup-actions button {
      background: #1f263e;
      border: none;
      padding: 12px 28px;
      border-radius: 60px;
      font-weight: 600;
      color: #fff;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      border: 1px solid #3f4865;
      transition: 0.15s;
      font-size: 1rem;
      flex: 1 0 auto;
      justify-content: center;
    }
    .popup-actions .call-btn {
      background: #4caf7a;
      border-color: #4caf7a;
      color: #0b0e1a;
    }
    .popup-actions .copy-btn {
      background: #2d3557;
      border-color: #4e5880;
    }
    .popup-actions .close-btn {
      background: transparent;
      border: 1px solid #5a6385;
      color: #aab2cc;
      flex: 0.5;
    }
    .popup-actions button:hover {
      filter: brightness(1.15);
      transform: scale(1.02);
    }

    @media (max-width: 600px) {
      .navbar { flex-direction: column; align-items: stretch; gap: 12px; }
      .nav-links { justify-content: center; gap: 16px; }
      .nav-right { justify-content: center; }
      .hero h2 { font-size: 1.7rem; }
      .hero-buttons .btn-hero { width: 100%; justify-content: center; }
      .about-image-box .image-placeholder { height: 150px; }
    }
  </style>
</head>
