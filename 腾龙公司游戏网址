    .feature-tags span {
      background: #1f263e;
      padding: 6px 18px;
      border-radius: 40px;
      font-size: 0.85rem;
      border: 1px solid #353e5a;
    }

    .feature-tags i {
      color: #f5c842;
      margin-right: 6px;
    }

    .about-image-box {
      background: #101624;
      border-radius: 28px;
      border: 1px solid #2a3147;
      padding: 20px;
      display: flex;
      flex-direction: column;
      box-shadow: 0 6px 18px rgba(0,0,0,0.4);
    }

    .about-image-box .image-placeholder {
      background: linear-gradient(145deg, #1d233b, #0e1325);
      border-radius: 20px;
      height: 200px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px dashed #4e5880;
      margin-bottom: 18px;
      position: relative;
      overflow: hidden;
    }

    .image-placeholder i {
      font-size: 4rem;
      color: #f5c842;
      opacity: 0.6;
    }

    .image-placeholder span {
      position: absolute;
      bottom: 16px;
      background: #0b0e1a;
      padding: 6px 24px;
      border-radius: 30px;
      font-size: 0.8rem;
      color: #b9c2e0;
      border: 1px solid #3d4663;
    }

    .record-number {
      margin-top: 6px;
      background: #0b0f1e;
      padding: 12px 16px;
      border-radius: 40px;
      text-align: center;
      font-size: 0.9rem;
      color: #8d97b9;
      border: 1px solid #2b324b;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }

    .record-number i {
      color: #f5c842;
      font-size: 1.2rem;
    }

    .record-number strong {
      color: #d4defa;
      font-weight: 500;
      letter-spacing: 1px;
    }

    .section-grid {
